{
  "name": "@genesis/qa-lab",
  "version": "2026.4.20",
  "private": true,
  "description": "Genesis QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "dependencies": {
    "@copilotkit/aimock": "1.14.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "playwright-core": "1.59.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@genesis/plugin-sdk": "workspace:*",
    "genesis": "workspace:*"
  },
  "peerDependencies": {
    "genesis": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "genesis": {
      "optional": true
    }
  },
  "genesis": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@genesis/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    }
  }
}
