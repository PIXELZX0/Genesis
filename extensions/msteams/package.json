{
  "name": "@genesis/msteams",
  "version": "2026.4.20",
  "description": "Genesis Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/teams.api": "2.0.8",
    "@microsoft/teams.apps": "2.0.8",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "typebox": "1.1.31"
  },
  "devDependencies": {
    "@genesis/plugin-sdk": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "genesis": "workspace:*"
  },
  "peerDependencies": {
    "genesis": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "genesis": {
      "optional": true
    }
  },
  "genesis": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      }
    },
    "install": {
      "npmSpec": "@genesis/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "genesisVersion": "2026.4.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
