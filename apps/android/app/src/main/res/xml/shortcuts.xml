<shortcuts xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <capability
        android:name="custom.actions.intent.ASK_GENESIS"
        app:queryPatterns="@array/ask_genesis_query_patterns">
        <intent
            android:action="ai.genesis.app.action.ASK_GENESIS"
            android:targetPackage="ai.genesis.app"
            android:targetClass="ai.genesis.app.MainActivity">
            <parameter
                android:name="prompt"
                android:key="prompt"
                android:mimeType="https://schema.org/Text"
                android:required="true" />
        </intent>
    </capability>
</shortcuts>
