// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

GENESIS_CODE_SIGN_STYLE = Manual
GENESIS_DEVELOPMENT_TEAM = Y5PE65HELJ

GENESIS_APP_BUNDLE_ID = ai.genesis.client
GENESIS_SHARE_BUNDLE_ID = ai.genesis.client.share
GENESIS_WATCH_APP_BUNDLE_ID = ai.genesis.client.watchkitapp
GENESIS_WATCH_EXTENSION_BUNDLE_ID = ai.genesis.client.watchkitapp.extension
GENESIS_ACTIVITY_WIDGET_BUNDLE_ID = ai.genesis.client.activitywidget

GENESIS_APP_PROFILE = ai.genesis.client Development
GENESIS_SHARE_PROFILE = ai.genesis.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
